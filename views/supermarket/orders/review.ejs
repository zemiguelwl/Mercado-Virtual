<div class="bo-page-header">
  <div>
    <h1 class="h3 mb-1">Registar avaliação</h1>
    <p class="bo-page-subtitle">Avaliação do estafeta responsável pela entrega.</p>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <% if (locals.order.deliveryMethod === "courier" && locals.delivery && locals.delivery.courier) { %>
      <form method="POST" action="/supermarket/orders/<%= locals.order._id %>/review" class="row g-3">
        <div class="col-12 col-md-4">
          <label class="form-label" for="courierRating">Avaliação do estafeta (1–5)</label>
          <input id="courierRating" name="courierRating" type="number" min="1" max="5" class="form-control" required>
        </div>
        <div class="col-12">
          <label class="form-label" for="courierComment">Comentário (opcional)</label>
          <textarea id="courierComment" name="courierComment" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-12">
          <button class="btn btn-primary" type="submit">Submeter avaliação</button>
          <a href="/supermarket/orders/<%= locals.order._id %>" class="btn btn-outline-secondary ms-2">Cancelar</a>
        </div>
      </form>
    <% } else { %>
      <p class="text-muted mb-3">Esta encomenda não teve entrega por estafeta — não há avaliação para registar.</p>
      <a href="/supermarket/orders/<%= locals.order._id %>" class="btn btn-outline-secondary">Voltar à encomenda</a>
    <% } %>
  </div>
</div>
