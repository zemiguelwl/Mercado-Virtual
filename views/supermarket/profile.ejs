<% const sm = locals.supermarket || {}; %>
<% const pickup = sm.deliveryMethods && sm.deliveryMethods.find((m) => m.type === "pickup"); %>
<% const courier = sm.deliveryMethods && sm.deliveryMethods.find((m) => m.type === "courier"); %>
<%
function parseDay(val) {
  if (!val || val === "Fechado") return { open: false, from: "09:00", to: "18:00" };
  const m = val.match(/^(\d{2}:\d{2})-(\d{2}:\d{2})$/);
  if (!m) return { open: false, from: "09:00", to: "18:00" };
  return { open: true, from: m[1], to: m[2] };
}
const sch = sm.schedule || {};
const days = [
  { key: "monday",    label: "Segunda",  d: parseDay(sch.monday) },
  { key: "tuesday",   label: "Terça",    d: parseDay(sch.tuesday) },
  { key: "wednesday", label: "Quarta",   d: parseDay(sch.wednesday) },
  { key: "thursday",  label: "Quinta",   d: parseDay(sch.thursday) },
  { key: "friday",    label: "Sexta",    d: parseDay(sch.friday) },
  { key: "saturday",  label: "Sábado",   d: parseDay(sch.saturday) },
  { key: "sunday",    label: "Domingo",  d: parseDay(sch.sunday) }
];
%>

<div class="bo-page-header">
  <div>
    <h1 class="h3 mb-1">Perfil do supermercado</h1>
    <p class="bo-page-subtitle">Configuração da loja, horários e métodos de entrega.</p>
  </div>
</div>

<div class="row g-3">
  <div class="col-12 col-lg-8">
    <div class="card">
      <div class="card-body">
        <form method="POST" action="/supermarket/profile" class="row g-3">
          <div class="col-12 col-md-6">
            <label class="form-label" for="name">Nome</label>
            <input id="name" class="form-control" name="name" value="<%= sm.name || '' %>" required>
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label" for="phone">Telefone</label>
            <input id="phone" class="form-control" name="phone" value="<%= sm.phone || '' %>">
          </div>
          <div class="col-12">
            <label class="form-label" for="location">Morada</label>
            <input id="location" class="form-control" name="location" value="<%= sm.location || '' %>" required>
          </div>
          <div class="col-12">
            <label class="form-label" for="description">Descrição</label>
            <textarea id="description" class="form-control" name="description" rows="3"><%= sm.description || '' %></textarea>
          </div>
          <div class="col-12">
            <div class="form-check">
              <input id="isOpen" class="form-check-input" type="checkbox" name="isOpen" <%= sm.isOpen ? "checked" : "" %>>
              <label class="form-check-label" for="isOpen">Supermercado aberto</label>
            </div>
          </div>

          <div class="col-12"><h2 class="h5 mt-2 mb-1">Horário semanal</h2></div>

          <% for (const day of days) { %>
          <div class="col-12 schedule-row">
            <div class="d-flex align-items-center gap-3 flex-wrap py-1 border-bottom pb-2">
              <span class="fw-medium text-secondary" style="min-width:72px"><%= day.label %></span>
              <div class="form-check form-switch mb-0">
                <input class="form-check-input schedule-toggle" type="checkbox" role="switch"
                       id="<%= day.key %>Open" name="<%= day.key %>Open" value="on"
                       <%= day.d.open ? "checked" : "" %>>
                <label class="form-check-label" for="<%= day.key %>Open">
                  <span class="schedule-state-label"><%= day.d.open ? "Aberto" : "Fechado" %></span>
                </label>
              </div>
              <div class="schedule-times d-flex align-items-center gap-2"
                   style="<%= !day.d.open ? 'display:none' : '' %>">
                <input type="time" class="form-control form-control-sm" name="<%= day.key %>From"
                       value="<%= day.d.from %>" style="width:120px">
                <span class="text-muted">–</span>
                <input type="time" class="form-control form-control-sm" name="<%= day.key %>To"
                       value="<%= day.d.to %>" style="width:120px">
              </div>
            </div>
          </div>
          <% } %>

          <div class="col-12"><h2 class="h5 mt-2 mb-0">Métodos de entrega</h2></div>
          <div class="col-12 col-md-6">
            <div class="form-check mb-2">
              <input id="pickupActive" class="form-check-input" type="checkbox" name="pickupActive" <%= pickup && pickup.active ? "checked" : "" %>>
              <label class="form-check-label" for="pickupActive">Levantamento em loja ativo</label>
            </div>
            <label class="form-label" for="pickupCost">Custo pickup (€)</label>
            <input id="pickupCost" class="form-control" type="number" step="0.01" name="pickupCost" value="<%= (pickup && pickup.cost) || 0 %>">
          </div>
          <div class="col-12 col-md-6">
            <div class="form-check mb-2">
              <input id="courierActive" class="form-check-input" type="checkbox" name="courierActive" <%= courier && courier.active ? "checked" : "" %>>
              <label class="form-check-label" for="courierActive">Entrega ao domicílio ativa</label>
            </div>
            <label class="form-label" for="courierCost">Custo courier (€)</label>
            <input id="courierCost" class="form-control" type="number" step="0.01" name="courierCost" value="<%= (courier && courier.cost) || 0 %>">
          </div>

          <div class="col-12">
            <button class="btn btn-primary" type="submit">Guardar alterações</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-4">
    <div class="card">
      <div class="card-header bg-white">
        <h2 class="h5 mb-0">Estado da loja</h2>
      </div>
      <div class="card-body">
        <p class="mb-3">
          Estado atual:
          <span class="badge text-bg-<%= sm.isOpen ? 'success' : 'secondary' %>">
            <%= sm.isOpen ? "Aberta" : "Fechada" %>
          </span>
        </p>
        <form method="POST" action="/supermarket/profile/toggle-open">
          <button class="btn btn-outline-<%= sm.isOpen ? 'danger' : 'success' %> w-100" type="submit">
            <%= sm.isOpen ? "Fechar loja" : "Abrir loja" %>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll(".schedule-toggle").forEach(function (toggle) {
  toggle.addEventListener("change", function () {
    const row = this.closest(".schedule-row");
    const timesDiv = row.querySelector(".schedule-times");
    const label = row.querySelector(".schedule-state-label");
    if (this.checked) {
      timesDiv.style.display = "";
      label.textContent = "Aberto";
    } else {
      timesDiv.style.display = "none";
      label.textContent = "Fechado";
    }
  });
});
</script>
