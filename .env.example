# ---------------------------------------------------------
# Mercadinho Virtual - Template de Configuração Ambiental
# ---------------------------------------------------------

# Ambiente (development | production)
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Base de Dados (MongoDB)
DB_URI=insere_aqui
# Sessão e Segurança
SESSION_SECRET=insere_aqui

# Configuração de Email (Mailtrap)
# O registo de novos utilizadores depende destas chaves.
EMAIL_API_TOKEN=token_aqui
EMAIL_FROM=insere_aqui

# Notas:
# 1. Em 'production', o cookie de sessão exige HTTPS (secure: true).
# 2. Se EMAIL_API_TOKEN estiver vazio, usa o seed.js para criar users pré-verificados.